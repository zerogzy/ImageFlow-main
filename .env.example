APP_NAME=ImageFlow
APP_ENV=production
APP_DEBUG=false

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=imageflow
DB_USERNAME=root
DB_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600

# Authentication
ADMIN_API_KEY=your-admin-api-key
GUEST_API_KEY=your-guest-api-key

# Storage: local or s3
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# S3 Configuration (when STORAGE_TYPE=s3)
S3_ENDPOINT=https://s3.us-west-000.backblazeb2.com
S3_REGION=us-west-000
S3_BUCKET=imageflow
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_CUSTOM_DOMAIN=

# Image Processing
MAX_UPLOAD_COUNT=20
IMAGE_QUALITY=80
THUMBNAIL_WIDTHS=400,800,1200
THUMBNAIL_QUALITY=80
IMAGE_PROCESSING_THREADS=4
WORKER_POOL_SIZE=4

# Server
ALLOWED_ORIGINS=*
