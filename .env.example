# 管理员密钥（用于上传、删除、修改标签等管理操作）
API_KEY=your_admin_api_key_here

# 访客密钥（可选，不设置则图片广场公开访问）
# GUEST_API_KEY=your_guest_api_key_here

# 存储配置
STORAGE_TYPE=local
METADATA_STORE_TYPE=redis
LOCAL_STORAGE_PATH=static/images

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS_ENABLED=false

# S3 配置（仅当 STORAGE_TYPE=s3 时需要）
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
CUSTOM_DOMAIN=

# 上传与图片处理配置
MAX_UPLOAD_COUNT=20
IMAGE_QUALITY=75
WORKER_THREADS=4
SPEED=5
WORKER_POOL_SIZE=4

# 后端地址（Next.js 服务端 rewrites 代理用，不暴露给浏览器）
# 单机部署：http://127.0.0.1:8686
# Docker 部署：http://backend:8686
BACKEND_URL=http://127.0.0.1:8686

# Next.js Image 组件允许的远程图片域名（逗号分隔，客户端变量）
# 示例：https://img.your_domain.com
NEXT_PUBLIC_REMOTE_PATTERNS=

# CORS 允许的域名（逗号分隔，留空则允许公开访问但不可携带凭证）
# 示例：https://your_domain.com,http://localhost:3000
ALLOWED_ORIGINS=

# 调试模式
DEBUG_MODE=false
